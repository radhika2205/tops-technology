        "# Task 1: Save & Load a Delivery Time Predictor\n",
        "\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import joblib\n",
        "import os\n",
        "\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.linear_model import LinearRegression\n",
        "from sklearn.metrics import root_mean_squared_error\n",
        "\n",
        "# -------------------------------\n",
        "# Step 1: Generate Dummy Dataset\n",
        "# -------------------------------\n",
        "\n",
        "np.random.seed(42)\n",
        "\n",
        "n = 100\n",
        "\n",
        "distance_km = np.random.uniform(1, 20, n)\n",
        "num_items = np.random.randint(1, 10, n)\n",
        "rain_flag = np.random.randint(0, 2, n)\n",
        "\n",
        "# Create target with some noise\n",
        "delivery_time_min = (\n",
        "    10\n",
        "    + (distance_km * 3)\n",
        "    + (num_items * 2)\n",
        "    + (rain_flag * 8)\n",
        "    + np.random.normal(0, 2, n)\n",
        ")\n",
        "\n",
        "data = pd.DataFrame({\n",
        "    \"distance_km\": distance_km,\n",
        "    \"num_items\": num_items,\n",
        "    \"rain_flag\": rain_flag,\n",
        "    \"delivery_time_min\": delivery_time_min\n",
        "})\n",
        "\n",
        "print(\"First 5 Rows:\\n\")\n",
        "print(data.head())\n",
        "\n",
        "# -------------------------------\n",
        "# Step 2: Split Dataset\n",
        "# -------------------------------\n",
        "\n",
        "X = data[[\"distance_km\", \"num_items\", \"rain_flag\"]]\n",
        "y = data[\"delivery_time_min\"]\n",
        "\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    X, y,\n",
        "    test_size=0.20,\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "# -------------------------------\n",
        "# Step 3: Train Model\n",
        "# -------------------------------\n",
        "\n",
        "model = LinearRegression()\n",
        "model.fit(X_train, y_train)\n",
        "\n",
        "# -------------------------------\n",
        "# Step 4: Evaluate Model\n",
        "# -------------------------------\n",
        "\n",
        "predictions = model.predict(X_test)\n",
        "\n",
        "rmse = root_mean_squared_error(y_test, predictions)\n",
        "\n",
        "print(\"\\nRMSE on Test Data:\", round(rmse, 2))\n",
        "\n",
        "# -------------------------------\n",
        "# Step 5: Save Model\n",
        "# -------------------------------\n",
        "\n",
        "filename = \"delivery_model.joblib\"\n",
        "\n",
        "joblib.dump(model, filename)\n",
        "\n",
        "file_size_kb = os.path.getsize(filename) / 1024\n",
        "\n",
        "print(f\"\\nModel saved successfully as '{filename}'\")\n",
        "print(f\"File Size: {file_size_kb:.2f} KB\")\n",
        "\n",
        "# -------------------------------\n",
        "# Step 6: Reload Model\n",
        "# -------------------------------\n",
        "\n",
        "loaded_model = joblib.load(filename)\n",
        "\n",
        "print(\"\\nModel loaded successfully.\")\n",
        "\n",
        "# -------------------------------\n",
        "# Step 7: Predict New Sample\n",
        "# -------------------------------\n",
        "\n",
        "new_sample = pd.DataFrame({\n",
        "    \"distance_km\": [8],\n",
        "    \"num_items\": [4],\n",
        "    \"rain_flag\": [1]\n",
        "})\n",
        "\n",
        "original_prediction = model.predict(new_sample)\n",
        "loaded_prediction = loaded_model.predict(new_sample)\n",
        "\n",
        "print(\"\\nOriginal Model Prediction:\", original_prediction[0])\n",
        "print(\"Reloaded Model Prediction:\", loaded_prediction[0])\n",
        "\n",
        "# -------------------------------\n",
        "# Step 8: Compare Predictions\n",
        "# -------------------------------\n",
        "\n",
        "if np.allclose(original_prediction, loaded_prediction):\n",
        "    print(\"\\nPASS: Predictions are identical.\")\n",
        "else:\n",
        "    print(\"\\nFAIL: Predictions do not match.\")\n",
        "\n"
